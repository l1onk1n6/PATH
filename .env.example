# ── Supabase ─────────────────────────────────────────────────────────────────
# Project URL — found in Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Anon (public) key — safe to expose in the browser bundle
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Cloudflare Turnstile ──────────────────────────────────────────────────────
# Site key — found in Cloudflare Dashboard → Turnstile → your widget
# Omit or leave empty to disable Turnstile in local dev (contact form still works)
VITE_TURNSTILE_SITE_KEY=0x4AAAAAAC...

# ── Supabase Edge Function Secrets ────────────────────────────────────────────
# These are set via `supabase secrets set` — NOT in this file.
# Listed here for reference only.
#
# SUPABASE_SERVICE_ROLE_KEY   (set automatically by Supabase runtime)
# ZAMMAD_URL                  Base URL of your Zammad instance
# ZAMMAD_TOKEN                Zammad API token (ticket.agent permission)
# TURNSTILE_SECRET_KEY        Cloudflare Turnstile secret key
# SMTP_HOST                   SMTP server hostname
# SMTP_PORT                   SMTP port (587 = STARTTLS, 465 = SSL)
# SMTP_USER                   SMTP username
# SMTP_PASS                   SMTP password
# SMTP_FROM                   Sender address, e.g. "PATH <noreply@pixmatic.ch>"
# APP_ORIGIN                  Allowed CORS origin for track-view (default: https://path.pixmatic.ch)

# ── GitHub Actions Secrets ────────────────────────────────────────────────────
# These are set in GitHub → Settings → Secrets → Actions.
# Listed here for reference only.
#
# VITE_SUPABASE_URL            Same as above (injected at build time)
# VITE_SUPABASE_ANON_KEY       Same as above (injected at build time)
# SUPABASE_ACCESS_TOKEN        Supabase CLI access token (for Edge Function deploy)
# SUPABASE_PROJECT_ID          Supabase project ref (e.g. xxxxxxxxxxxxxxxxxxxx)
# TURNSTILE_SECRET_KEY         Cloudflare Turnstile secret (deployed as Edge Function secret)
